generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IdentityUserStatus {
  ACTIVE
  INACTIVE
}

/// Inquilino genérico: centro, consola admin dotbin, otro producto, etc.
/// Clave lógica: userId + clientId. userId = id (cuid).
/// Email único por clientId; reglas globales opcionales arriba de esto.
model IdentityUser {
  id                     String             @id @default(cuid())
  clientId               String
  email                  String
  passwordHash           String
  name                   String?
  status                 IdentityUserStatus @default(ACTIVE)
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@unique([clientId, email])
  @@index([clientId])
}
