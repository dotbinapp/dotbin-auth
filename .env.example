NODE_ENV=development
PORT=4100

DATABASE_URL=postgresql://user:password@localhost:5432/dotbin_auth

# Llamadas internas desde dotbin-server (CRUD /v1/users)
INTERNAL_API_KEY=cambia-por-un-secreto-largo-minimo-8-chars

# Opcional: devolver el token de reset en JSON (solo desarrollo; en prod enviar por email)
# RETURN_RESET_TOKEN_IN_RESPONSE=false

# PASSWORD_RESET_EXPIRES_MINUTES=60
# BCRYPT_ROUNDS=12

# JWT emitidos por este servicio
# JWT_ISSUER=https://auth.tu-dominio.com
# JWT_AUDIENCE=estetik-api
